<%- include('../layout', { title: 'Daftar Member', body: `
<section>
  <div class="page-title"><h2>Daftar Member</h2></div>
  <div class="form-card">
    ${errors.length ? `<div class="alert">${errors.join('<br>')}</div>` : ''}
    <form method="POST" action="/member/register">
      <label for="name">Nama Lengkap</label>
      <input id="name" name="name" type="text" placeholder="Nama lengkap" required />

      <label for="email">Email</label>
      <input id="email" name="email" type="email" placeholder="email@example.com" required />

      <label for="password">Password</label>
      <div class="password-field-container">
        <input id="password" name="password" type="password" placeholder="Minimal 6 karakter" required />
        <button type="button" class="toggle-password" aria-label="Tunjukkan password">
          <svg class="eye" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7S2 12 2 12z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="eye-off" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 3l18 18" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10.58 10.58A3 3 0 0 0 13.42 13.42" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 12s4-7 10-7c2.07 0 3.98.58 5.66 1.57" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21.02 16.11A15.88 15.88 0 0 0 22 12s-4 7-10 7c-2.06 0-3.98-.58-5.66-1.57" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <label for="phone">No HP</label>
      <input id="phone" name="phone" type="text" placeholder="08xxxxxxxxxx" required />

      <label for="address">Alamat</label>
      <textarea id="address" name="address" placeholder="Alamat lengkap" required></textarea>

      <button class="btn" type="submit">Daftar</button>
    </form>
    <p>Sudah punya akun? <a href="/member/login">Login di sini</a></p>
  </div>
</section>
` }) %>